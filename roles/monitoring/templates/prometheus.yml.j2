global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets: ["localhost:9090"]

  # Scrapes node-exporter running on the host via host.docker.internal.
  # Currently targets a single host — in a multi-server setup this list should be
  # templated dynamically from the Ansible inventory (e.g. using groups['vps']).
  - job_name: node-exporter
    static_configs:
      - targets: ["host.docker.internal:{{ node_exporter_port }}"]
